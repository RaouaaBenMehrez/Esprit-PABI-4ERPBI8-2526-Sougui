# ─── Backend Flask ────────────────────────────────────────────────────────────
# PostgreSQL Connection
PG_HOST=localhost
PG_PORT=5432
PG_DB=sougui_db
PG_USER=postgres
PG_PASSWORD=your_postgres_password_here

# Flask
FLASK_ENV=development
FLASK_SECRET_KEY=your_secret_key_here

# ─── AI Agent (FastAPI) ───────────────────────────────────────────────────────
# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (optionnel, si utilisé)
OPENAI_API_KEY=your_openai_api_key_here

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Dans frontend/.env.local (Vite expose les variables VITE_*)
VITE_API_URL=http://127.0.0.1:5000
VITE_AGENT_URL=http://127.0.0.1:8000
